    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.67.0",
    "p-queue": "^9.1.0",
    "puppeteer": "^24.39.1",
    "resend": "^6.9.4",
    "winston": "^3.19.0"
  }
