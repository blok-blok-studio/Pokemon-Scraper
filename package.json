{
  "name": "pokemon-card-agent",
  "version": "1.0.0",
  "description": "Autonomous Pokemon TCG card deal hunting agent running on OpenClaw",
  "main": "tools/startup.js",
  "scripts": {
    "start": "node tools/startup.js",
    "dashboard": "node tools/dashboard/dashboard-cli.js start",
    "test:db": "node tools/db/database.test.js",
    "test:tcg": "node tools/scraper-engine/tcgplayer.test.js",
    "test:ebay": "node tools/scraper-engine/ebay.test.js",
    "test:analyzer": "node tools/analyzer/cardAnalyzer.test.js",
    "test:telegram": "node tools/telegram-client/telegram.test.js",
    "test:email": "node tools/resend-client/emailOutreach.test.js",
    "test:voice": "node tools/bland-client/voiceOutreach.test.js",
    "test:dashboard": "node tools/dashboard/dashboard.test.js",
    "test:proxy": "node tools/scraper-engine/proxyManager.test.js",
    "test:matcher": "node tools/utils/cardMatcher.test.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:smoke": "vitest run tests/smoke",
    "test:all": "vitest run",
    "backup": "node tools/backup-db.js",
    "export:deals": "node tools/export/export-cli.js deals",
    "export:outreach": "node tools/export/export-cli.js outreach"
  },
  "keywords": [
    "pokemon",
    "tcg",
    "cards",
    "agent",
    "openclaw"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@deepgram/sdk": "^5.0.0",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.8.0",
    "csv-stringify": "^6.7.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.67.0",
    "p-queue": "^9.1.0",
    "puppeteer": "^24.39.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "resend": "^6.9.4",
    "twilio": "^5.13.0",
    "winston": "^3.19.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  }
}
