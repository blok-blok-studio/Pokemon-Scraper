# ═══════════════════════════════════════════════════════════
# Pokemon Card Agent — Environment Variables
# Copy this to .env and fill in your real values
# ═══════════════════════════════════════════════════════════

# ── Required: AI Analysis ──
# Powers deal analysis, email generation, voice scripts, reply analysis
# Get your key at: https://console.anthropic.com → API Keys
# Cost: ~$0.50-2.00/day depending on scrape volume
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Required: Telegram Bot ──
# Sends deal alerts, accepts commands (/status, /deals, /spend, etc.)
# Create a bot: message @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Get your chat ID: message @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Required for Email Outreach ──
# Sends personalized emails to card shops and sellers
# Sign up at: https://resend.com → API Keys
# Free tier: 100 emails/day
RESEND_API_KEY=your_resend_api_key_here
# Must use a verified domain on Resend (e.g., deals@yourdomain.com)
FROM_EMAIL=your_verified_resend_email
# Where sellers reply to (can be same as FROM_EMAIL or a different inbox)
REPLY_TO_EMAIL=your_reply_email

# ── Required for Voice Outreach ──
# Makes AI phone calls to card shops
# Sign up at: https://deepgram.com → API Keys
# Free tier: $200 credit
DEEPGRAM_API_KEY=your_deepgram_api_key_here
# Sign up at: https://console.twilio.com
# Get SID + Auth Token from the dashboard
# Buy a phone number (~$1.15/month) at: Console → Phone Numbers → Buy
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1your_twilio_phone_number

# ── Optional: Testing ──
# Your real email for testing outreach (sends actual emails)
TEST_EMAIL=your_test_email
# Your real phone for testing voice calls (makes actual calls)
TEST_PHONE=your_test_phone

# ── Optional: Agent Settings ──
# Name the agent uses when introducing itself on voice calls
AGENT_NAME=your_name_for_voice_calls
# Port for the local dashboard (default: 3847)
AGENT_PORT=3847
# Max API spend per day in USD — agent stops making API calls when reached
DAILY_API_SPEND_CAP_USD=5.00
# Public URL for Twilio to send call events back to your agent
# For local testing: use ngrok (ngrok http 3847) and paste the URL here
# For production: your server's public URL
# VOICE_SERVER_URL=https://your-ngrok-url.ngrok.io

# ── Cloud CRM Sync ──
# Set these AFTER deploying the CRM to Vercel (Prompt 9+)
# Your Vercel deployment URL
CRM_SYNC_URL=https://your-pokemon-crm.vercel.app
# Shared secret — must match SYNC_API_KEY in Vercel environment
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRM_SYNC_API_KEY=your_shared_sync_secret
